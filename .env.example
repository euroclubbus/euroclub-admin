# Firebase config з мобільного додатку euroclub-app (той самий проєкт).
# Firebase Console -> Project Settings -> General -> Your apps -> SDK setup and config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Пароль входу в панель (проста перевірка на фронті, не справжня автентифікація).
VITE_ADMIN_PASSWORD=

# --- Тільки для Vercel env vars, НЕ для локального .env з префіксом VITE_ ---
# Повний JSON service account ключа (Firebase Console -> Project Settings ->
# Service Accounts -> Generate new private key), вставити як один рядок.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
